# ========================================
# EVCA Admin Mobile App - Environment Variables
# ========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ========================================
# API Configuration
# ========================================

# Base URL for API requests
# Local development: http://localhost:3000
# Production: https://api.evca.com
API_BASE_URL=https://emobility-bff.dev.dhemax.link/

# API request timeout in milliseconds (default: 30000 = 30 seconds)
API_TIMEOUT=30000

# HTTP Logging level (for debugging API calls)
# 0 = off (no logging)
# 1 = basic (URL + status code) - default
# 2 = detailed (+ request/response headers)
# 3 = verbose (+ request/response bodies)
HTTP_LOG_LEVEL=3

# ========================================
# Authentication
# ========================================

# OAuth/Login configuration
AUTH_PROVIDER=keycloak
AUTH_REALM=evca
AUTH_CLIENT_ID=admin-evca-mobile

# Token encryption key (must be 32 characters for AES-256)
# Generate with: openssl rand -hex 16
TOKEN_ENCRYPTION_KEY=your-32-char-encryption-key-here

# ========================================
# App Configuration
# ========================================

# Environment: development, staging, production
ENVIRONMENT=development

# App version (should match package.json)
APP_VERSION=1.0.0

# Debug mode (enables detailed console logging)
DEBUG=true

# Feature flags
ENABLE_MOCK_API=false
ENABLE_OFFLINE_SUPPORT=true

# ========================================
# Services
# ========================================

# Analytics (optional)
ANALYTICS_ENABLED=false
ANALYTICS_KEY=

# Crash reporting (optional)
SENTRY_ENABLED=false
SENTRY_DSN=

# ========================================
# Localization
# ========================================

# Default language: es (Spanish), en (English)
DEFAULT_LANGUAGE=es

# ========================================
# UI Configuration
# ========================================

# Default theme: light, dark, system
DEFAULT_THEME=system

# ========================================
# EAS Build Configuration (optional)
# ========================================

# EAS Project ID for CI/CD
EAS_PROJECT_ID=

# EAS Build channel
EAS_BUILD_CHANNEL=production
