# ========================================
# EVCA Admin Mobile App - Development Environment
# ========================================

# ========================================
# API Configuration
# ========================================
API_BASE_URL=https://emobility-bff.dev.dhemax.link/
API_TIMEOUT=30000
HTTP_LOG_LEVEL=3

# ========================================
# Authentication
# ========================================
AUTH_PROVIDER=keycloak
AUTH_REALM=evca
AUTH_CLIENT_ID=admin-evca-mobile
TOKEN_ENCRYPTION_KEY=your-32-char-encryption-key-here

# ========================================
# App Configuration
# ========================================
ENVIRONMENT=development
APP_VERSION=1.0.0
DEBUG=true
ENABLE_MOCK_API=false
ENABLE_OFFLINE_SUPPORT=true

# ========================================
# Services
# ========================================
ANALYTICS_ENABLED=false
ANALYTICS_KEY=
SENTRY_ENABLED=false
SENTRY_DSN=

# ========================================
# Localization
# ========================================
DEFAULT_LANGUAGE=es
DEFAULT_THEME=system

# ========================================
# EAS Build Configuration
# ========================================
EAS_PROJECT_ID=
EAS_BUILD_CHANNEL=development
