  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@evca.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{API_BASE_URL}}/bff/auth/login",
              "host": ["{{API_BASE_URL}}"],
              "path": ["bff", "auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{API_BASE_URL}}/bff/auth/refresh-token",
              "host": ["{{API_BASE_URL}}"],
              "path": ["bff", "auth", "refresh-token"]
            }
          }
        },
