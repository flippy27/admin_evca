{
  "info": {
    "name": "EVCA Admin API",
    "description": "Complete API endpoints for EVCA Admin mobile app testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@evca.com\",\n  \"password\": \"password123\",\n  \"rememberMe\": true\n}"
            },
            "url": {
              "raw": "{{API_BASE_URL}}/api/auth/login",
              "host": ["{{API_BASE_URL}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{API_BASE_URL}}/api/auth/refresh",
              "host": ["{{API_BASE_URL}}"],
              "path": ["api", "auth", "refresh"]
            }
          }
        },
        {
          "name": "Get Permissions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{API_BASE_URL}}/api/auth/permissions",
              "host": ["{{API_BASE_URL}}"],
              "path": ["api", "auth", "permissions"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{API_BASE_URL}}/api/auth/logout",
              "host": ["{{API_BASE_URL}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
